// Tables
Table User {
  id         integer   [pk, increment]
  fullName   varchar
  phone      varchar   [null]
  email      varchar   [unique]
  password   varchar
  userType   varchar
  verified   boolean   [default: false]
  avatar     varchar   [null]
  gender     Gender
  createdAt  timestamp [default: `now()`]
  updatedAt  timestamp
}

Table JobSeekerProfile {
  id        integer   [pk, increment]
  userId    integer   [unique, ref: - User.id]
}

Table Agency {
  id         integer   [pk, increment]
  name       varchar   [unique]
  country    Country
  location   varchar
  verified   boolean
  createdAt  timestamp [default: `now()`]
  updatedAt  timestamp
}

Table AgencyUserProfile {
  id         integer   [pk, increment]
  agencyId   integer   [ref: > Agency.id]
  userId     integer   [unique, ref: - User.id]
  userType   AgencyRole
  createdAt  timestamp [default: `now()`]
  updatedAt  timestamp
}

Table File {
  id         integer   [pk, increment]
  userId     integer   [ref: > User.id]
  fileUrl    varchar
  fileType   varchar    // e.g. CV, ID, Certification, Business Document
  uploadedAt timestamp  [default: `now()`]
}

Table Job {
  id          integer    [pk, increment]
  agencyId    integer    [ref: > Agency.id]
  title       varchar
  description text
  location    varchar
  salary      varchar
  skills      varchar[]  // array of strings
  isActive    boolean
  createdAt   timestamp  [default: `now()`]
  updatedAt   timestamp
}

Table JobApplication {
  id          integer               [pk, increment]
  jobId       integer               [ref: > Job.id]
  applicantId integer               [ref: > User.id]
  status      JobApplicationStatus
  createdAt   timestamp             [default: `now()`]
  updatedAt   timestamp
}

Table Contract {
  id         integer   [pk, increment]
  userId     integer   [ref: > User.id]
  fileUrl    varchar
  createdAt  timestamp [default: `now()`]
  updatedAt  timestamp
}

Table Payment {
  id         integer        [pk, increment]
  payerId    integer        [ref: > User.id]
  payeeId    integer        [ref: > User.id]
  agencyId   integer
  amount     decimal
  status     PaymentStatus  [default: 'pending']
  createdAt  timestamp      [default: `now()`]
  updatedAt  timestamp
}

Table Blog {
  id          integer   [pk, increment]
  author      varchar
  title       varchar
  slug        varchar   [unique]
  content     text
  language    varchar
  publishedAt timestamp
  createdAt   timestamp  [default: `now()`]
  updatedAt   timestamp
}