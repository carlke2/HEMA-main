// Enums
Enum Gender {
  Male
  Female
  Other
}

Enum AgencyRole {
  HR
  Admin
  Support
  Finance
}

Enum PaymentStatus {
  pending
  completed
  failed
  refunded
}

Enum JobApplicationStatus {
  applied
  in_review
  interview
  offered
  rejected
  hired
}

