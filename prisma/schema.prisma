generator client {
    provider      = "prisma-client-js"
    binaryTargets = ["native", "debian-openssl-1.1.x"]
}

datasource db {
    provider = "postgresql"
    url      = env("DATABASE_URL")
}

model User {
    id            Int       @id @default(autoincrement())
    fullName      String
    phone         String?
    email         String    @unique
    password      String
    userType      UserType
    verified      Boolean   @default(false)
    avatar        String?
    gender        Gender
    dateOfBirth   DateTime?
    firstLoginAt  DateTime?
    createdAt     DateTime  @default(now())
    updatedAt     DateTime  @updatedAt

    jobSeekerProfile      JobSeekerProfile?
    agencyUserProfile     AgencyUserProfile?
    HostFamilyUserProfile HostFamilyUserProfile?
    AuPairUserProfile     AuPairUserProfile?
    files                 File[]
    jobApplications       JobApplication[]       @relation("ApplicantApplications")
    contracts             Contract[]
    paymentsMade          Payment[]              @relation("PaymentsMade")
    paymentsReceived      Payment[]              @relation("PaymentsReceived")
    AuPairContracts           AuPairContract[]
    interestsAsAuPair         FamilyAuPairInterest[]
    notifications             Notification[]
    trainingAssignments  TrainingAssignment[]
    trainingProgress     TrainingProgress[]
}

model Training {
    id          Int      @id @default(autoincrement())
    title       String
    description String?
    sortOrder   Int      @default(0)
    createdAt   DateTime @default(now())
    updatedAt   DateTime @updatedAt

    steps        TrainingStep[]
    assignments  TrainingAssignment[]
}

model TrainingStep {
    id          Int      @id @default(autoincrement())
    trainingId  Int
    title       String
    description String?
    sortOrder   Int      @default(0)
    createdAt   DateTime @default(now())
    updatedAt   DateTime @updatedAt

    training Training          @relation(fields: [trainingId], references: [id], onDelete: Cascade)
    progress TrainingProgress[]
}

model TrainingAssignment {
    id        Int      @id @default(autoincrement())
    userId    Int
    trainingId Int
    assignedAt DateTime @default(now())
    assignedByUserId Int?

    user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
    training Training @relation(fields: [trainingId], references: [id], onDelete: Cascade)

    @@unique([userId, trainingId])
}

model TrainingProgress {
    id            Int       @id @default(autoincrement())
    userId        Int
    trainingStepId Int
    completedAt   DateTime?
    createdAt     DateTime  @default(now())
    updatedAt     DateTime  @updatedAt

    user  User         @relation(fields: [userId], references: [id], onDelete: Cascade)
    step  TrainingStep @relation(fields: [trainingStepId], references: [id], onDelete: Cascade)

    @@unique([userId, trainingStepId])
}

model JobSeekerProfile {
    id        Int      @id @default(autoincrement())
    userId    Int      @unique
    user      User     @relation(fields: [userId], references: [id])
    country   Country?
    location  String?
    skills    String[] @default([])
    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt
}

model AuPairUserProfile {
    id        Int            @id @default(autoincrement())
    userId    Int            @unique
    user      User           @relation(fields: [userId], references: [id])
    country   Country?
    location  String?
    tribe     AfricanTribes?
    religion  Religion?
    education String?
    skills    String[]       @default([])
    createdAt DateTime       @default(now())
    updatedAt DateTime       @updatedAt
}

model Agency {
    id          Int      @id @default(autoincrement())
    uuid        String   @unique @default(uuid())
    name        String
    country     Country
    location    String
    verified    Boolean  @default(false)
    createdAt   DateTime @default(now())
    updatedAt   DateTime @updatedAt
    avatar      String?
    description String?
    website     String?
    socialLinks String[] @default([])
    email       String?
    avatarUrl   String?

    jobs      Job[]
    users     AgencyUserProfile[]
    contracts Contract[]

    @@unique([name, country], map: "agency_name_country_key")
}

model AgencyUserProfile {
    id        Int        @id @default(autoincrement())
    agencyId  String
    agency    Agency     @relation(fields: [agencyId], references: [uuid])
    userType  AgencyRole
    country   Country?
    location  String?
    createdAt DateTime   @default(now())
    updatedAt DateTime   @updatedAt

    userId Int  @unique
    user   User @relation(fields: [userId], references: [id])
}

model HostFamily {
    id          Int            @id @default(autoincrement())
    uuid        String         @unique @default(uuid())
    name        String
    country     Country
    tribe       AfricanTribes?
    religion    String?
    location    String
    verified    Boolean        @default(false)
    createdAt   DateTime       @default(now())
    updatedAt   DateTime       @updatedAt
    avatar      String?
    description String?
    socialLinks String[]       @default([])
    email       String?
    avatarUrl   String?
    children    Child[]

    users     HostFamilyUserProfile[]
    contracts AuPairContract[]
    interests FamilyAuPairInterest[]
}

model HostFamilyUserProfile {
    id        Int        @id @default(autoincrement())
    familyId  String
    family    HostFamily @relation(fields: [familyId], references: [uuid])
    country   Country?
    location  String?
    createdAt DateTime   @default(now())
    updatedAt DateTime   @updatedAt

    userId Int  @unique
    user   User @relation(fields: [userId], references: [id])
}

model Child {
    id           Int         @id @default(autoincrement())
    familyId     String
    name         String
    yob          DateTime
    HostFamily   HostFamily? @relation(fields: [hostFamilyId], references: [uuid])
    hostFamilyId String?
}

model File {
    id         Int      @id @default(autoincrement())
    userId     Int
    user       User     @relation(fields: [userId], references: [id])
    fileName   String
    fileUrl    String   @unique
    fileType   FileType
    uploadedAt DateTime @default(now())

    jobApplications JobApplication[] @relation("ApplicationFiles")

    @@unique([userId, fileUrl], map: "file_owner_url_key")
}

model Job {
    id          Int         @id @default(autoincrement())
    agencyId    String
    agency      Agency      @relation(fields: [agencyId], references: [uuid])
    title       String
    description String
    category    JobCategory
    country     Country
    location    String
    salary      Int
    currency    Currency
    skills      String[]    @default([])
    isActive    Boolean
    createdAt   DateTime    @default(now())
    updatedAt   DateTime    @updatedAt

    jobApplications JobApplication[]
}

model JobApplication {
    id          Int                  @id @default(autoincrement())
    jobId       Int
    applicantId Int
    files       File[]               @relation("ApplicationFiles")
    job         Job                  @relation(fields: [jobId], references: [id])
    applicant   User                 @relation("ApplicantApplications", fields: [applicantId], references: [id])
    status      JobApplicationStatus
    createdAt   DateTime             @default(now())
    updatedAt   DateTime             @updatedAt
}

model Contract {
    id                     Int             @id @default(autoincrement())
    userId                 Int
    user                   User            @relation(fields: [userId], references: [id])
    agencyId               String
    agency                 Agency          @relation(fields: [agencyId], references: [uuid])
    jobTitle               String
    description            String
    duties                 String
    startDate              DateTime
    endDate                DateTime
    salary                 Decimal
    salaryFrequency        SalaryFrequency
    currency               Currency
    workingHours           String
    leaveAndVacationPolicy String
    terminationConditions  String
    status                 ContractStatus  @default(ACTIVE)
    createdAt              DateTime        @default(now())
    updatedAt              DateTime        @updatedAt

    @@unique([userId, agencyId], map: "contract_user_agency_job_unique")
}

model AuPairContract {
    id                     Int             @id @default(autoincrement())
    userId                 Int
    user                   User            @relation(fields: [userId], references: [id])
    familyId               String
    family                 HostFamily      @relation(fields: [familyId], references: [uuid])
    description            String
    duties                 String
    startDate              DateTime
    endDate                DateTime
    salary                 Decimal
    salaryFrequency        SalaryFrequency
    currency               Currency
    workingHours           String
    leaveAndVacationPolicy String
    terminationConditions  String
    matchScore             Int             @default(0)
    status                 ContractStatus  @default(PENDING)
    createdAt              DateTime        @default(now())
    updatedAt              DateTime        @updatedAt

    @@unique([userId, familyId], map: "contract_user_hostfamily_aupair_unique")
}

enum InterestStatus {
  FAMILY_INTERESTED
  AU_PAIR_INTERESTED
  AU_PAIR_UNINTERESTED
  MEET_SCHEDULED
  MEET_DONE
  OFFER_EXTENDED
  FAMILY_DECLINED
}

model FamilyAuPairInterest {
  id                Int           @id @default(autoincrement())
  familyId          String
  family            HostFamily    @relation(fields: [familyId], references: [uuid])
  userId             Int
  user               User          @relation(fields: [userId], references: [id])
  status             InterestStatus @default(FAMILY_INTERESTED)
  scheduledMeetAt    DateTime?
  meetingLink        String?
  meetNotes          String?
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt

  @@unique([familyId, userId], map: "interest_family_aupair_unique")
}

model Notification {
  id          Int       @id @default(autoincrement())
  userId      Int
  user        User      @relation(fields: [userId], references: [id])
  type        String
  title       String
  message     String
  relatedType String?
  relatedId   String?
  readAt      DateTime?
  createdAt   DateTime  @default(now())
}

model Payment {
    id        Int           @id @default(autoincrement())
    payerId   Int
    payer     User          @relation("PaymentsMade", fields: [payerId], references: [id])
    payeeId   Int
    payee     User          @relation("PaymentsReceived", fields: [payeeId], references: [id])
    agencyId  Int
    amount    Decimal
    currency  Currency
    status    PaymentStatus @default(pending)
    createdAt DateTime      @default(now())
    updatedAt DateTime      @updatedAt
}

model Blog {
    id          String   @id @default(cuid())
    title       String
    content     String
    tags        String[]
    type        String
    thumbnail   String?
    identifier  String   @unique
    createdAt   DateTime @default(now())
    updatedAt   DateTime @default(now())
    description String   @default("More about this blog")
    ifPreview   Boolean  @default(false)
}

